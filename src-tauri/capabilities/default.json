{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window on macOS. NOTE: when adding a new LLM/STT/TTS provider, add its API host to the http: scope below AND to CSP connect-src in tauri.conf.json.",
  "windows": ["main", "dashboard"],
  "platforms": ["macOS"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-set-webview-position",
    "core:webview:allow-set-webview-size",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-position",
    "core:window:allow-set-size",
    "core:window:allow-set-focus",
    "core:window:allow-outer-size",
    "core:window:allow-current-monitor",
    "core:window:allow-start-resize-dragging",
    "core:event:default",
    "opener:default",
    "log:default",
    "macos-permissions:default",
    "keychain:default",
    "keychain:allow-get-item",
    "keychain:allow-save-item",
    "keychain:allow-remove-item",
    "global-shortcut:allow-is-registered",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "core:window:allow-start-dragging",
    "sql:default",
    "sql:allow-select",
    "sql:allow-execute",
    "posthog:default",
    "posthog:allow-capture",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api.groq.com/**" },
        { "url": "https://api.elevenlabs.io/**" },
        { "url": "https://www.googleapis.com/**" },
        { "url": "https://app.posthog.com/**" },
        { "url": "https://api.github.com/**" }
      ]
    }
  ]
}
