{
  "name": "@krishna/brain",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Krishna Brain — headless Node service: shared memory/skills store, encrypted at rest, REST + WS + SSE chat.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "fetch:node": "tsx scripts/fetch-node.ts",
    "build:bundle": "npm run fetch:node && tsx scripts/bundle-brain.ts",
    "start:pm2": "pm2 start ecosystem.config.cjs",
    "stop:pm2": "pm2 stop krishna-brain",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "gmail:auth": "tsx src/gmail/auth-cli.ts"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.2",
    "@krishna/core": "*",
    "@libsql/client": "^0.15.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/keyring": "^1.1.7",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "googleapis": "^134.0.0",
    "pm2": "^6.0.5",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.22.4",
    "typescript": "~5.8.3",
    "vitest": "^4.1.4"
  }
}
