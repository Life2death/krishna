# --- Krishna Brain configuration ---
# Copy to .env and fill in. NEVER commit .env.

# HTTP/WS port the brain listens on
KRISHNA_BRAIN_PORT=8787

# Shared bearer token every client must send (Authorization: Bearer <token>).
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KRISHNA_BRAIN_TOKEN=

# Local libSQL/SQLite database file (embedded replica primary).
KRISHNA_DB_PATH=./krishna-brain.db

# --- Turso cloud sync (optional; leave blank for local-only) ---
# When set, the local DB becomes an embedded replica that syncs to Turso.
KRISHNA_SYNC_URL=
KRISHNA_SYNC_TOKEN=
# Seconds between background syncs (0 = sync only on writes)
KRISHNA_SYNC_INTERVAL=60

# --- Field encryption master key ---
# Preferred: leave blank -> a 256-bit key is generated and stored in the OS keyring.
# Fallback (headless/CI): provide a 32-byte key as hex(64 chars) or base64.
KRISHNA_MASTER_KEY=

# --- Chat (/chat) LLM provider: Anthropic Claude ---
ANTHROPIC_API_KEY=
KRISHNA_CLAUDE_MODEL=claude-sonnet-4-6
