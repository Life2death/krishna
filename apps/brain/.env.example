# --- Krishna Brain configuration ---
# Copy to .env and fill in. NEVER commit .env.

# HTTP/WS port the brain listens on
KRISHNA_BRAIN_PORT=8787

# Shared bearer token every client must send (Authorization: Bearer <token>).
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KRISHNA_BRAIN_TOKEN=

# Local libSQL/SQLite database file (embedded replica primary).
# In Docker, mount a volume at /data/ so the DB persists across restarts.
KRISHNA_DB_PATH=./krishna-brain.db

# --- Turso cloud sync (optional; leave blank for local-only) ---
# When set, the local DB becomes an embedded replica that syncs to Turso.
# Sign up: https://turso.tech  |  Install CLI: npm i -g @libsql/turso  |  turso db create krishna
# Then: turso db show krishna --url   and   turso db tokens create krishna
KRISHNA_SYNC_URL=
KRISHNA_SYNC_TOKEN=
# Seconds between background syncs (0 = sync only on writes)
KRISHNA_SYNC_INTERVAL=60

# --- Field encryption master key ---
# Preferred: leave blank -> a 256-bit key is generated and stored in the OS keyring.
# Fallback (headless/CI/Docker): provide a 32-byte key as hex(64 chars) or base64.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KRISHNA_MASTER_KEY=

# --- Chat (/chat) LLM provider: Anthropic Claude ---
# Required for /chat and /conversations/:id/resume-summary endpoints.
ANTHROPIC_API_KEY=
KRISHNA_CLAUDE_MODEL=claude-sonnet-4-6

# --- Speech-to-Text (for /dictate endpoint) (optional) ---
# URL of a compatible STT API (e.g. Deepgram, Whisper via OpenAI-compatible API).
# The brain sends a multipart form with an "audio" field.
KRISHNA_STT_URL=
KRISHNA_STT_API_KEY=
KRISHNA_STT_MODEL=

# --- Telegram bot (optional) ---
# Create a bot via @BotFather on Telegram, then paste the token here.
# The bot will poll for messages and route them through Krishna's brain.
TELEGRAM_BOT_TOKEN=

# --- MCP tool hub (optional) ---
# Path to a JSON file with an array of MCP server configs.
# KRISHNA_MCP_CONFIG_PATH=./mcp-servers.json
#
# Or inline JSON (takes precedence when both set):
# KRISHNA_MCP_SERVERS=[{"name":"filesystem","transport":"stdio","command":"npx","args":["-y","@modelcontextprotocol/server-filesystem","/tmp"]}]
#
# Each server entry format:
# { "name": string, "transport": "stdio"|"sse", "command"?: string, "args"?: string[], "url"?: string }

# --- RAG knowledge base ---
# RAG uses local embeddings (Xenova/all-MiniLM-L6-v2, runs locally, no API key).
# No additional configuration needed — it indexes memories on first boot.
# Set KRISHNA_RAG_DISABLED=true to skip RAG initialization.

# --- Fact extraction ---
# POST /conversations/:id/extract-facts uses Claude to extract facts from
# conversations and optionally save them as memories. Requires ANTHROPIC_API_KEY.

# --- Production / Docker ---
# NODE_ENV=production  (optional — pm2 sets this automatically when using ecosystem.config.cjs)
